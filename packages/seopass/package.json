{
  "name": "@unclick/seopass",
  "version": "0.1.0",
  "description": "SEOPass - public-safe search-engine readiness verdicts for websites.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "packs"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./verdict-pack": {
      "types": "./dist/verdict-pack.d.ts",
      "import": "./dist/verdict-pack.js"
    },
    "./lighthouse": {
      "types": "./dist/lighthouse.d.ts",
      "import": "./dist/lighthouse.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc --project tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
