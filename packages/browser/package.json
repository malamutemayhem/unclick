{
  "name": "@unclick/browser",
  "version": "0.1.0",
  "description": "UnClick Browser - reading-first, agent-native conversion core (HTML to UnClick Doc, plus the consistent renderer).",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./format": "./dist/format.js",
    "./convert": "./dist/convert.js",
    "./render": "./dist/render.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc --project tsconfig.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "node demo/run.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
