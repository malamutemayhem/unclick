{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UnClick Browser",
  "version": "0.5.3",
  "identifier": "world.unclick.browser",
  "build": {
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "UnClick Browser",
        "width": 1100,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/malamutemayhem/unclick/releases/download/browser-app-latest/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwRjUyNzgyQkVCMzIxQgpSV1FiTXVzcmVGSVBDVDBtakRkaEt3K1Bva3JZZHFJQlk0QjR2Q29OY2JnbjFCaGRmMGx6U3E3Tgo="
    }
  }
}